<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DrukLink AI</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Modern Pro UI Theme (ChatGPT / Grok Style) */
        :root {
            --sidebar-bg: #171717;
            --main-bg: #212121;
            --user-msg-bg: #2f2f2f;
            --text-main: #ececec;
            --text-muted: #b4b4b4;
            --accent: #10a37f; /* ChatGPT Green */
            --input-bg: #2f2f2f;
            --border-color: rgba(255,255,255,0.1);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--main-bg); color: var(--text-main); font-family: 'Inter', -apple-system, sans-serif; height: 100vh; overflow: hidden; }
        .hidden { display: none !important; }

        /* Auth Screen */
        #auth-screen { background: var(--main-bg); height: 100vh; display: flex; justify-content: center; align-items: center; }
        .login-card { background: var(--sidebar-bg); border: 1px solid var(--border-color); padding: 50px; border-radius: 12px; text-align: center; width: 100%; max-width: 400px; }
        .google-btn { width: 100%; padding: 14px; background: white; color: black; border-radius: 8px; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 20px; cursor: pointer; border: none; font-size: 16px;}

        /* Layout */
        #app { display: flex; height: 100vh; }
        .sidebar { width: 260px; background: var(--sidebar-bg); display: flex; flex-direction: column; padding: 20px 10px; }
        .main-container { flex: 1; display: flex; flex-direction: column; position: relative; }

        /* Sidebar Navigation */
        #side-logo { font-weight: 600; font-size: 1.1rem; padding: 0 10px; margin-bottom: 30px; color: var(--text-main); }
        .nav-item { padding: 12px 15px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 12px; transition: 0.2s; margin-bottom: 4px; color: var(--text-muted); font-size: 14px;}
        .nav-item:hover { background: rgba(255,255,255,0.05); color: var(--text-main); }
        .nav-item.active { background: rgba(255,255,255,0.1); color: var(--text-main); font-weight: 500; }

        /* Main Chat Screen */
        .screen { flex: 1; display: flex; flex-direction: column; height: 100%; overflow-y: auto; }
        #chat-feed { flex: 1; display: flex; flex-direction: column; padding: 40px 0; width: 100%; max-width: 800px; margin: 0 auto; }
        
        /* Message Styling (ChatGPT approach) */
        .msg-wrapper { display: flex; width: 100%; padding: 15px 20px; margin-bottom: 15px; }
        
        /* User Message: Right aligned rounded bubble */
        .msg-wrapper.user { justify-content: flex-end; }
        .msg.user { background: var(--user-msg-bg); color: var(--text-main); padding: 12px 20px; border-radius: 24px; max-width: 70%; line-height: 1.6; font-size: 15px; }
        
        /* AI Message: Left aligned, plain text with icon */
        .msg-wrapper.ai { justify-content: flex-start; gap: 15px; }
        .ai-icon { width: 30px; height: 30px; background: white; color: black; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
        .msg.ai { background: transparent; color: var(--text-main); max-width: 85%; line-height: 1.6; font-size: 15px; padding-top: 4px; }

        /* Input Box */
        .input-wrap { padding: 20px; background: linear-gradient(180deg, transparent, var(--main-bg) 30%); position: sticky; bottom: 0; width: 100%; display: flex; justify-content: center; }
        .input-box { background: var(--input-bg); border: 1px solid rgba(255,255,255,0.15); padding: 8px 15px; border-radius: 24px; display: flex; align-items: center; gap: 10px; width: 100%; max-width: 800px; box-shadow: 0 0 15px rgba(0,0,0,0.1); }
        input { flex: 1; background: transparent; border: none; color: var(--text-main); outline: none; font-size: 15px; padding: 8px; }
        
        button.send-btn { background: var(--text-main); color: var(--main-bg); border: none; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s; }
        button.send-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        button.send-btn:hover:not(:disabled) { opacity: 0.8; }

        /* Generic Settings/Profile UI */
        .settings-container { max-width: 600px; margin: 40px auto; width: 100%; }
        .card { background: var(--user-msg-bg); padding: 25px; border-radius: 12px; margin-top: 20px; }
        .styled-input { width: 100%; background: var(--main-bg); border: 1px solid var(--border-color); padding: 12px; border-radius: 8px; color: white; margin-bottom: 15px; margin-top: 5px;}
        .primary-btn { background: var(--text-main); color: var(--main-bg); padding: 10px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; border: none;}

        @media (max-width: 768px) { .sidebar { width: 0; padding: 0; display: none; } #chat-feed { padding: 20px 10px; } }
    </style>
</head>
<body>

    <div id="auth-screen">
        <div class="login-card">
            <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 8px;">DrukLink AI</h1>
            <p style="color: var(--text-muted); font-size: 14px;">Log in to continue</p>
            <button class="google-btn" onclick="login()">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/action/google.svg" width="20"> Continue with Google
            </button>
        </div>
    </div>

    <div id="app" class="hidden">
        <aside class="sidebar">
            <div id="side-logo">DrukLink AI</div>
            <nav>
                <div class="nav-item active" onclick="switchTab('chat', this)"><i class="fas fa-comment-alt"></i> New Chat</div>
                <div class="nav-item" onclick="switchTab('history', this)"><i class="fas fa-clock"></i> History</div>
                <div class="nav-item" onclick="switchTab('profile', this)"><i class="fas fa-user"></i> Profile</div>
                <div class="nav-item" onclick="switchTab('settings', this)"><i class="fas fa-cog"></i> Settings</div>
            </nav>
            <div style="margin-top: auto; border-top: 1px solid var(--border-color); padding-top: 10px;">
                <div class="nav-item" onclick="logout()" style="color: #ef4444;"><i class="fas fa-sign-out-alt"></i> Log out</div>
            </div>
        </aside>

        <main class="main-container">
            
            <div id="chat-screen" class="screen">
                <div id="chat-feed"></div>
                <div class="input-wrap">
                    <div class="input-box">
                        <input type="text" id="userInput" placeholder="Message DrukLink AI..." onkeypress="if(event.key === 'Enter') sendMsg()">
                        <button id="sendBtn" onclick="sendMsg()" class="send-btn"><i class="fas fa-arrow-up"></i></button>
                    </div>
                </div>
            </div>

            <div id="history-screen" class="screen hidden">
                <div class="settings-container">
                    <h2 style="margin-bottom: 20px;">Chat History</h2>
                    <div id="history-list"></div>
                </div>
            </div>

            <div id="profile-screen" class="screen hidden">
                <div class="settings-container">
                    <h2>My Profile</h2>
                    <div class="card">
                        <img id="profile-pic" style="width: 80px; border-radius: 50%; margin-bottom:15px; display: block;">
                        <label style="color: var(--text-muted); font-size: 14px;">Display Name</label>
                        <input type="text" id="display-name-input" class="styled-input">
                        <button class="primary-btn" onclick="updateProfile()">Save Changes</button>
                    </div>
                </div>
            </div>

            <div id="settings-screen" class="screen hidden">
                <div class="settings-container">
                    <h2>Settings</h2>
                    <div class="card" style="line-height: 1.8;">
                        <p>Provider: <b>OpenRouter API</b></p>
                        <p>Model: <b>Google Gemini 1.5 Flash</b></p>
                        <p>Connection: <b id="ai-status" style="color: #eab308;">Initializing...</b></p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.11.0/firebase-app.js";
        import { getAuth, signInWithPopup, GoogleAuthProvider, onAuthStateChanged, signOut, updateProfile as firebaseUpdateProfile } from "https://www.gstatic.com/firebasejs/12.11.0/firebase-auth.js";
        import { getFirestore, collection, addDoc, onSnapshot, query, where, serverTimestamp, doc, setDoc } from "https://www.gstatic.com/firebasejs/12.11.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyCxPbybzZwn1GbzwMqJ-6zRyI7TRSKvgs0",
            authDomain: "druklink-24fa1.firebaseapp.com",
            projectId: "druklink-24fa1",
            storageBucket: "druklink-24fa1.firebasestorage.app",
            messagingSenderId: "183615496366",
            appId: "1:183615496366:web:fcfb4f88f3223044924d3f"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        
        let user = null;
        let openRouterKey = null;

        // FETCH OPENROUTER KEY
        async function fetchAPIKey() {
            try {
                const response = await fetch('/api/config');
                const data = await response.json();
                
                if (data.apiKey) {
                    openRouterKey = data.apiKey;
                    document.getElementById('ai-status').innerText = "Connected";
                    document.getElementById('ai-status').style.color = "#10a37f"; // Green
                }
            } catch (err) {
                document.getElementById('ai-status').innerText = "Disconnected";
                document.getElementById('ai-status').style.color = "#ef4444";
            }
        }
        fetchAPIKey();

        // AUTHENTICATION
        window.login = () => signInWithPopup(auth, new GoogleAuthProvider());
        window.logout = () => signOut(auth);

        onAuthStateChanged(auth, async (u) => {
            if (u) {
                user = u;
                document.getElementById('auth-screen').classList.add('hidden');
                document.getElementById('app').classList.remove('hidden');
                document.getElementById('profile-pic').src = u.photoURL;
                document.getElementById('display-name-input').value = u.displayName || "User";
                
                loadMessages();
                loadHistory();
            } else {
                document.getElementById('auth-screen').classList.remove('hidden');
                document.getElementById('app').classList.add('hidden');
            }
        });

        // UI TAB SWITCHER
        window.switchTab = (tabId, el) => {
            document.querySelectorAll('.screen').forEach(s => s.classList.add('hidden'));
            document.getElementById(tabId + '-screen').classList.remove('hidden');
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            el.classList.add('active');
        };

        // UI HELPERS FOR CHAT BUBBLES
        function addUserMessageUI(text) {
            const feed = document.getElementById('chat-feed');
            feed.innerHTML += `
                <div class="msg-wrapper user">
                    <div class="msg user">${text}</div>
                </div>`;
            feed.scrollTop = feed.scrollHeight;
        }

        function addAIMessageUI(text, id = null) {
            const feed = document.getElementById('chat-feed');
            const idAttr = id ? `id="${id}"` : "";
            // Format line breaks properly
            const formattedText = text.replace(/\n/g, '<br>');
            feed.innerHTML += `
                <div class="msg-wrapper ai" ${idAttr}>
                    <div class="ai-icon"><i class="fas fa-link"></i></div>
                    <div class="msg ai">${formattedText}</div>
                </div>`;
            feed.scrollTop = feed.scrollHeight;
        }

        // SEND MESSAGE VIA OPENROUTER
        window.sendMsg = async () => {
            const input = document.getElementById('userInput');
            const btn = document.getElementById('sendBtn');
            const val = input.value.trim();
            
            if (!val || !user) return;
            if (!openRouterKey) {
                alert("API is still connecting la. Please wait a second.");
                return;
            }

            // 1. Show user message instantly
            addUserMessageUI(val);
            
            // 2. Show "Thinking" animation
            const tempId = "thinking-" + Date.now();
            addAIMessageUI('<i class="fas fa-circle-notch fa-spin"></i>', tempId);

            input.value = "";
            btn.disabled = true;

            try {
                // 3. Make the API Call to OpenRouter
                const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
                    method: "POST",
                    headers: {
                        "Authorization": `Bearer ${openRouterKey}`,
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        "model": "google/gemini-1.5-flash", // You can change this to ANY OpenRouter model!
                        "messages": [
                            {"role": "system", "content": "You are DrukLink AI, a highly intelligent and helpful assistant from Bhutan. Always be polite, concise, and greet with 'Kuzuzangpo la' on the first interaction."},
                            {"role": "user", "content": val}
                        ]
                    })
                });

                const data = await response.json();
                
                if(data.error) throw new Error(data.error.message);

                const aiText = data.choices[0].message.content;

                // 4. Save to Firebase
                await addDoc(collection(db, "chats"), {
                    uid: user.uid,
                    prompt: val,
                    response: aiText,
                    time: serverTimestamp()
                });
            } catch (err) {
                console.error("OpenRouter Error:", err);
                document.getElementById(tempId).innerHTML = `<div class="msg ai" style="color:#ef4444;">Error la: ${err.message}</div>`;
            } finally {
                btn.disabled = false;
            }
        };

        // LOAD MESSAGES
        function loadMessages() {
            const q = query(collection(db, "chats"), where("uid", "==", user.uid));
            onSnapshot(q, (snap) => {
                let msgs = [];
                snap.forEach(d => msgs.push(d.data()));
                msgs.sort((a, b) => {
                    let tA = a.time ? a.time.toMillis() : Date.now();
                    let tB = b.time ? b.time.toMillis() : Date.now();
                    return tA - tB;
                });

                const feed = document.getElementById('chat-feed');
                feed.innerHTML = "";
                addAIMessageUI("Kuzuzangpo la! I am DrukLink AI. How can I help you today?");
                
                msgs.forEach(data => {
                    addUserMessageUI(data.prompt);
                    addAIMessageUI(data.response);
                });
            });
        }

        // LOAD HISTORY
        function loadHistory() {
            const q = query(collection(db, "chats"), where("uid", "==", user.uid));
            onSnapshot(q, (snap) => {
                const list = document.getElementById('history-list');
                let msgs = [];
                snap.forEach(d => msgs.push(d.data()));
                msgs.sort((a, b) => {
                    let tA = a.time ? a.time.toMillis() : Date.now();
                    let tB = b.time ? b.time.toMillis() : Date.now();
                    return tB - tA; 
                });

                list.innerHTML = "";
                msgs.forEach(data => {
                    list.innerHTML += `
                        <div class="card" style="margin-bottom:15px; margin-top:0;">
                            <small style="color:var(--text-muted);">${data.time?.toDate().toLocaleString() || 'Just now'}</small>
                            <p style="margin: 8px 0;"><b>You:</b> ${data.prompt}</p>
                            <p style="color:var(--text-muted);"><b>AI:</b> ${data.response.substring(0, 100)}...</p>
                        </div>`;
                });
            });
        }

        // UPDATE PROFILE
        window.updateProfile = async () => {
            const newName = document.getElementById('display-name-input').value;
            if(!newName) return;
            try {
                await firebaseUpdateProfile(auth.currentUser, { displayName: newName });
                await setDoc(doc(db, "users", user.uid), { name: newName }, { merge: true });
                alert("Profile Updated!");
            } catch (e) { alert("Error updating profile!"); }
        };
    </script>
</body>
</html>
